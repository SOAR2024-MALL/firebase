{
  "version": "1.1",

  "global_assets": {
    "css_base": "/assets/css/main.css",
    "js_base": "/assets/js/main.js",
    "image_base": "/assets/images/"
  },

  "store_asset_rules": {
    "bookstore": {
      "thumb_folder": "THUMBS",
      "content_folder": "PDFS"
    },

    "art": {
      "thumb_folder": "THUMBS",
      "content_folder": "ART"
    },

    "music": {
      "thumb_folder": "THUMBS",
      "content_folder": "PDFS"
    },

    "resources": {
      "thumb_folder": "THUMBS",
      "content_folder": "PDFS"
    }
  },

  "fallbacks": {
    "thumb": "/assets/images/default-thumb.png",
    "banner": "/assets/images/default-banner.png"
  },

  "rules": {
    "use_relative_store_paths": true,
    "never_hardcode_full_urls": true
  }
}
